{
  "rules": [
    {
      "type": "home",
      "description": "首页（控制台、工作台）",
      "keywords": ["首页", "控制台"]
    },
    {
      "type": "auth",
      "description": "认证页（登录、注册账号）",
      "keywords": ["登录", "账号登录", "手机号登录", "忘记密码", "注册账号"],
      "exclude": ["系统注册", "租户注册", "应用注册"]
    },
    {
      "type": "dashboard",
      "description": "仪表盘（数据统计、大屏展示）",
      "keywords": ["统计", "大屏"]
    },
    {
      "type": "list",
      "description": "列表页（数据列表展示）",
      "keywords": ["列表", "管理", "日志", "记录"]
    },
    {
      "type": "form",
      "description": "表单页（新增、申请、填写数据的页面）",
      "keywords": ["新增", "添加", "创建", "申请"]
    },
    {
      "type": "detail",
      "description": "详情页（查看数据详情的页面）",
      "keywords": ["详情", "详情页"]
    },
    {
      "type": "import",
      "description": "导入页（上传文件导入数据）",
      "keywords": ["导入", "上传"]
    },
    {
      "type": "export",
      "description": "导出页（导出数据下载）",
      "keywords": ["导出", "下载"]
    },
    {
      "type": "config",
      "description": "配置页（系统设置、参数配置）",
      "keywords": ["设置", "配置", "管理值"]
    },
    {
      "type": "search",
      "description": "搜索页（搜索结果展示）",
      "keywords": ["搜索"]
    },
    {
      "type": "selector",
      "description": "数据选择页（选择用户、产品、城市等数据的弹窗/页面）",
      "keywords": ["选择", "选取", "选择用户", "选择产品", "选择城市", "选择系统"]
    },
    {
      "type": "confirm",
      "description": "二次确认页（删除、启用禁用等操作的确认弹窗）",
      "keywords": ["确认删除", "是否删除", "确认启用", "确认禁用", "是否启用", "是否禁用", "二次确认"]
    },
    {
      "type": "result",
      "description": "结果页（操作完成后的结果展示）",
      "keywords": ["提交后", "完成"]
    },
    {
      "type": "static",
      "description": "静态页（帮助、协议、政策等）",
      "keywords": ["帮助", "协议", "政策", "规范", "隐私"],
      "exclude": ["登录日志", "操作日志", "访问日志", "系统日志"]
    }
  ],
  "default": "list",
  "defaultDescription": "列表页（数据列表展示，未匹配其他类型时的默认分类）"
}
